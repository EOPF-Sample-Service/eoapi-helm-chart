{"type": "Collection", "id": "sentinel-1-l1-slc", "stac_version": "1.1.0", "description": "The Sentinel-1 Level-1 Single Look Complex (SLC) products consist of focused SAR data, geo-referenced using orbit and attitude data from the satellite, and provided in slant-range geometry. Slant range is the natural radar range observation coordinate, defined as the line-of-sight from the radar to each reflecting object. The products are in zero-Doppler orientation where each row of pixels represents points along a line perpendicular to the sub-satellite track.", "links": [{"rel": "license", "href": "https://sentinel.esa.int/documents/247904/690755/Sentinel_Data_Legal_Notice", "type": "application/pdf", "title": "Legal notice on the use of Copernicus Sentinel Data and Service Information"}], "stac_extensions": ["https://stac-extensions.github.io/sar/v1.1.0/schema.json", "https://stac-extensions.github.io/view/v1.0.0/schema.json", "https://stac-extensions.github.io/sat/v1.0.0/schema.json", "https://stac-extensions.github.io/processing/v1.2.0/schema.json", "https://stac-extensions.github.io/product/v0.1.0/schema.json"], "item_assets": {"product": {"xarray:open_datatree_kwargs": {"engine": "eopf-zarr", "mode": "native", "chunks": {}}, "title": "EOPF Product", "description": "The full Zarr hierarchy of the EOPF product", "type": "application/vnd+zarr", "roles": ["data", "metadata"]}, "product_metadata": {"title": "Consolidated Metadata", "description": "Consolidated metadata of the EOPF product", "type": "application/json", "roles": ["metadata"]}}, "title": "Sentinel-1 Level-1 SLC", "extent": {"spatial": {"bbox": [[-180, -90, 180, 90]]}, "temporal": {"interval": [["2024-04-01T00:00:00Z", null]]}}, "license": "proprietary", "keywords": ["Copernicus", "Sentinel", "EU", "ESA", "Satellite", "SAR", "C-Band", "SLC"], "providers": [{"name": "European Commission", "roles": ["licensor"], "url": "https://commission.europa.eu/"}, {"name": "ESA", "roles": ["producer", "processor"], "url": "h